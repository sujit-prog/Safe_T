generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  checkHistory            CheckHistory[]
  guardianConnections     GuardianConnection[]
  activeTrips             ActiveTrip[]
  notificationSettings    UserNotificationSettings?
}

model CheckHistory {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  location  String
  score     Int
  status    String   // "Verified Safe", "Caution Advised", "Higher Risk"
  createdAt DateTime @default(now())
}

model NetworkAlert {
  id          String   @id @default(uuid())
  type        String   // "Alert", "Traffic", "Hazard", "Safety"
  location    String
  description String
  createdAt   DateTime @default(now())
  isVerified  Boolean  @default(false)
}

model GuardianConnection {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  guardianName   String
  guardianStatus String   // "Online", "Offline"
  createdAt      DateTime @default(now())
}

model SafeAnchor {
  id          String   @id @default(uuid())
  name        String
  type        String   // "Police Station", "Hospital", "24/7 Store"
  distanceStr String   // E.g., "1.2km"
  statusStr   String   // E.g., "24/7 Open", "ER Active"
  latitude    Float
  longitude   Float
  createdAt   DateTime @default(now())
}

model IncidentReport {
  id          String   @id @default(uuid())
  type        String   // e.g. "Accident", "Mugging", "Hazard", "Poor Lighting"
  severity    Int      // 1-10 scale
  description String?
  latitude    Float
  longitude   Float
  createdAt   DateTime @default(now())
}

model ActiveTrip {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id])
  startLocation  String
  endLocation    String
  startLat       Float
  startLng       Float
  endLat         Float
  endLng         Float
  currentLat     Float
  currentLng     Float
  status         String    @default("ACTIVE") // "ACTIVE", "COMPLETED", "SOS"
  sosTriggerCount Int      @default(0)
  lastPing       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model UserNotificationSettings {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id])
  alertThreshold     String   @default("MEDIUM") // "LOW", "MEDIUM", "HIGH"
  sosInactivitySecs  Int      @default(60)
  nightModeEnabled   Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}
